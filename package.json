{
  "name": "guralnik-mailer",
  "version": "2.0.2",
  "description": "Zero-code, premium multi-language email package for Medusa v2 and Node.js",
  "medusa": {
    "isPlugin": true
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./medusa": {
      "types": "./dist/medusa.d.ts",
      "import": "./dist/medusa.mjs",
      "require": "./dist/medusa.js"
    }
  },
  "bin": {
    "guralnik-mailer": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.tsx src/medusa.ts src/medusa/subscribers/order-handler.ts src/cli.ts --format cjs,esm --dts",
    "dev": "tsup src/index.tsx src/medusa.ts src/medusa/subscribers/order-handler.ts --format cjs,esm --dts --watch",
    "preview": "npx react-email dev --dir emails",
    "test": "tsx test-entwickler.tsx",
    "test:all": "tsx package-tests/run-all.ts",
    "test:live": "tsx package-tests/05-live-send.ts"
  },
  "dependencies": {
    "@react-email/components": "^1.0.8",
    "@sendgrid/mail": "^8.1.6",
    "firebase-admin": "^13.7.0",
    "nodemailer": "^8.0.1",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "prompts": "^2.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.2"
  },
  "peerDependencies": {
    "@medusajs/medusa": "^1.20.0 || ^2.0.0"
  },
  "devDependencies": {
    "@medusajs/medusa": "^1.20.11",
    "@react-email/preview-server": "^5.2.9",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^7.0.11",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "pino-pretty": "^13.1.3",
    "react-email": "^5.2.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
